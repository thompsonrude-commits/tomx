{
  "appId": "com.tomxtractor.49ja",
  "productName": "TomXtractor 49ja",
  "copyright": "Copyright © 2026 TomXtractor Professional",
  "directories": {
    "output": "app-release"
  },
  "files": [
    "dist/main/**/*",
    "dist/renderer/**/*",
    "resources/**/*",
    "package.json"
  ],
  "extraMetadata": {
    "main": "dist/main/main.js"
  },
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": ["x64"]
      }
    ],
    "icon": "resources/icon.ico",
    "artifactName": "TomXtractor_49ja_v${version}_Setup.exe",
    "publisherName": "TomXtractor"
  },
  "nsis": {
    "oneClick": false,
    "perMachine": false,
    "allowElevation": true,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": "always",
    "createStartMenuShortcut": true,
    "shortcutName": "TomXtractor 49ja",
    "runAfterFinish": true,
    "installerIcon": "resources/icon.ico",
    "uninstallerIcon": "resources/icon.ico",
    "license": "resources/LICENSE.txt"
  },
  "asar": true,
  "asarUnpack": [
    "node_modules/sql.js/**",
    "node_modules/chromium/**"
  ]
}
